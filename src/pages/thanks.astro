---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="Thanks — RECN" description="Thanks for following RECN mobile development.">
  <Header />
  <main class="simple-page simple-page--short shell" id="main-content">
    <header class="simple-page__header">
      <p class="label">THANKS</p>
      <h1>You’re on the list.</h1>
      <p>You’ll hear when there is a mobile build to try.</p>
    </header>
    <a class="inline-link" href={base}>Return home →</a>
  </main>
  <Footer />
</Base>
