---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConstellationField from '../components/ConstellationField.astro';

const base = import.meta.env.BASE_URL;
---

<Base
  title="RECN — Recordings, with context"
  description="Record audio, add notes, and find it later. RECN Rec is available for macOS and Windows; mobile is in development."
>
  <Header />

  <main id="main-content">
    <section class="home-hero shell">
      <div class="home-hero__copy">
        <p class="label">RECN REC</p>
        <h1>Record. Add a note.<br />Find it later.</h1>
        <p class="home-hero__intro">RECN keeps recordings, notes, and sessions together. Desktop is available now. Mobile is in development.</p>
        <div class="download-actions">
          <a class="button button--primary" href="https://github.com/recn-in/recn-releases/releases/latest/download/RECN-Rec-macOS.dmg">Download for macOS</a>
          <a class="button button--secondary" href="https://github.com/recn-in/recn-releases/releases/latest/download/RECN-Rec-Windows-Setup.exe">Download for Windows</a>
        </div>
        <p class="build-caveat">Early builds. Glitches are expected.</p>
      </div>
      <ConstellationField />
    </section>

    <section class="capability-list shell" aria-label="What RECN does">
      <article>
        <h2>Record</h2>
        <p>Capture audio and keep a note beside it.</p>
      </article>
      <article>
        <h2>Find</h2>
        <p>Search recordings, notes, and on-device transcripts.</p>
      </article>
      <article>
        <h2>Continue</h2>
        <p>Move work directly between nearby phone and desktop builds.</p>
      </article>
    </section>

    <section class="home-details shell">
      <div>
        <h2>Syncs nearby.</h2>
        <p>When RECN is open on the same reachable network, paired devices exchange library changes and media directly. There is no cloud relay in the current build.</p>
        <a class="inline-link" href={`${base}blog/inside-lattice/`}>How LAN sync works →</a>
      </div>
      <div>
        <h2>Mobile is next.</h2>
        <p>iOS is in device testing. Android is still being verified.</p>
        <a class="inline-link" href={`${base}mobile/`}>Mobile status →</a>
      </div>
    </section>

  </main>

  <Footer />
</Base>
