---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Showcase from '../components/Showcase.astro';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="RECN — Professional Audio Capture">
  <Header />
  <main>
    <!-- Hero -->
    <section class="hero container">
      <div class="accent-bar" style="width: 32px; margin: 0 auto var(--sp-md);"></div>
      <h1 class="hero-wordmark">RECN</h1>
      <p class="hero-version">Building tools for audio capture</p>
      <p class="hero-tagline">
        We're solving hard problems in on-device audio recording, ML-powered transcription, and multi-track capture — all running locally on your phone.
      </p>
      <form class="signup-form" action="https://formspree.io/f/xpqogbwd" method="post">
        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit">Follow Along</button>
      </form>
    </section>

    <!-- Showcase -->
    <section class="section container reveal">
      <h2 style="margin-bottom: var(--sp-lg);">Interface</h2>
      <Showcase />
    </section>

    <!-- What we're working on -->
    <section class="section container reveal">
      <h2 style="margin-bottom: var(--sp-lg);">What We're Solving</h2>
      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-tag">On-Device ML</span>
          <h3>Local Transcription Pipeline</h3>
          <p>Running speech-to-text models entirely on-device. No server round-trips, no data leaving your phone. Multilingual, offline, private by architecture.</p>
        </div>
        <div class="feature-card">
          <span class="feature-tag">Multi-Track</span>
          <h3>Mobile Overdub Engine</h3>
          <p>Building a multi-track recording and overdub system that works on mobile hardware. Layer tracks, mix with per-track faders, maintain sample-accurate sync.</p>
        </div>
        <div class="feature-card">
          <span class="feature-tag">Audio</span>
          <h3>Capture-Grade Recording</h3>
          <p>Five recording profiles from lossless RAW to compressed voice memo. Live waveform rendering, dB monitoring, zero-drop frame rates during capture.</p>
        </div>
        <div class="feature-card">
          <span class="feature-tag">Analysis</span>
          <h3>On-Device Classification</h3>
          <p>Speech vs music detection, key estimation, spectral analysis — all running locally through an extensible background processing pipeline.</p>
        </div>
      </div>
    </section>

    <!-- Where we are -->
    <section class="section container reveal">
      <h2 style="margin-bottom: var(--sp-lg);">Where We Are</h2>
      <div class="products-grid">
        <div class="product-card">
          <h3>RECN Rec Mobile</h3>
          <span class="product-status">Active</span>
          <p>The core recording app. On-device ML pipeline, multi-track editor, and DAW-ready export. iOS and Android.</p>
        </div>
        <div class="product-card">
          <h3>RECN Rec Desktop</h3>
          <span class="product-status">Pending</span>
          <p>Desktop companion. WiFi transfer from phone to workstation, library management, bridge to DAW.</p>
        </div>
        <div class="product-card">
          <h3>RecnCast</h3>
          <span class="product-status">Pending</span>
          <p>P2P audio streaming from DAW to browser. VST plugin captures the mix, WebRTC delivers it. No audio server.</p>
        </div>
      </div>
    </section>

    <!-- Log -->
    {posts.length > 0 && (
      <section class="section container reveal">
        <h2 style="margin-bottom: var(--sp-lg);">Log</h2>
        <div class="blog-grid">
          {posts.map(post => (
            <a href={`${base}blog/${post.slug}/`} class="blog-card">
              <div class="blog-card-meta">
                <span class="blog-card-date">{fmt(post.data.date)}</span>
                <span class="blog-card-category">{post.data.category}</span>
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.excerpt}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <section class="signup container reveal" style="padding-bottom: 64px;">
      <div class="accent-bar" style="width: 32px; margin: 0 auto var(--sp-md);"></div>
      <h2 style="margin-bottom: var(--sp-sm);">Recordings Are Sacred</h2>
      <p style="max-width: 420px; margin: 0 auto; text-wrap: balance; font-size: 0.8125rem;">
        Zero data loss. On-device processing. No cloud dependency.
      </p>
      <form class="signup-form" action="https://formspree.io/f/xpqogbwd" method="post">
        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit">Follow Along</button>
      </form>
    </section>
  </main>
  <Footer />
</Base>
