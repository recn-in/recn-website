---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Record audio, add notes, and find it later.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const socialImage = new URL(`${base}og-image.svg`, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta name="application-base" content={base} />
    <meta name="color-scheme" content="light dark" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RECN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <title>{title}</title>

    <script is:inline>
      (() => {
        const saved = localStorage.getItem('recn-theme');
        document.documentElement.dataset.theme = ['light', 'dark', 'amoled'].includes(saved) ? saved : 'light';
      })();
    </script>

  </head>
  <body>
    <slot />

    <script define:vars={{ base }} is:inline>
      (() => {
        const themeColors = { light: '#ffffff', dark: '#141414', amoled: '#000000' };
        const themeMeta = document.querySelector('meta[name="theme-color"]');
        const applyTheme = (theme, persist = true) => {
          if (!['light', 'dark', 'amoled'].includes(theme)) return;
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
          if (themeMeta) themeMeta.setAttribute('content', themeColors[theme]);
          document.querySelectorAll('[data-theme-choice]').forEach((button) => {
            const selected = button.getAttribute('data-theme-choice') === theme;
            button.setAttribute('aria-pressed', String(selected));
          });
          if (persist) localStorage.setItem('recn-theme', theme);
          window.dispatchEvent(new CustomEvent('recn-theme-change'));
        };

        document.querySelectorAll('[data-theme-choice]').forEach((button) => {
          button.addEventListener('click', () => applyTheme(button.getAttribute('data-theme-choice')));
        });
        applyTheme(document.documentElement.dataset.theme || 'light', false);

        document.querySelectorAll('[data-signup]').forEach((form) => {
          form.addEventListener('submit', async (event) => {
            event.preventDefault();
            const input = form.querySelector('input[type="email"]');
            const button = form.querySelector('button[type="submit"]');
            const status = form.querySelector('[data-form-status]');
            if (!input || !button || !status) return;

            const idleLabel = button.textContent;
            button.disabled = true;
            button.textContent = 'Sending…';
            status.textContent = '';

            try {
              const response = await fetch('https://formspree.io/f/xpqogbwd', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                body: JSON.stringify({ email: input.value }),
              });

              if (!response.ok) throw new Error(`Signup failed with ${response.status}`);
              window.location.assign(`${base}thanks/`);
            } catch (error) {
              status.textContent = 'That did not go through. Please try once more.';
              button.disabled = false;
              button.textContent = idleLabel;
            }
          });
        });
      })();
    </script>
  </body>
</html>
