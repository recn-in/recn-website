---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Professional audio capture for musicians and producers. No cloud, no compromise.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#000000" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <script is:inline>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
    })();
  </script>
</head>
<body>
  <canvas id="bg-canvas" aria-hidden="true"></canvas>
  <slot />

  <script is:inline>
    /* ---- Theme toggle: amoled → light → dark → amoled ---- */
    (function() {
      var themes = ['amoled', 'light', 'dark'];
      var colors = { amoled: '#000000', light: '#F5F5F3', dark: '#141414' };
      var btn = document.querySelector('.theme-toggle');
      if (!btn) return;

      function current() { return document.documentElement.dataset.theme || 'amoled'; }
      btn.textContent = current().toUpperCase();

      btn.addEventListener('click', function() {
        var idx = themes.indexOf(current());
        var next = themes[(idx + 1) % 3];
        if (next === 'amoled') {
          delete document.documentElement.dataset.theme;
        } else {
          document.documentElement.dataset.theme = next;
        }
        localStorage.setItem('theme', next);
        btn.textContent = next.toUpperCase();
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.content = colors[next];
      });
    })();

    /* ---- Signup form → Formspree, then redirect to /thanks ---- */
    (function() {
      document.querySelectorAll('[data-signup]').forEach(function(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var btn = form.querySelector('button');
          var email = form.querySelector('input[type="email"]').value;
          btn.textContent = '...';
          btn.disabled = true;
          fetch('https://formspree.io/f/xpqogbwd', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ email: email })
          }).then(function() {
            window.location.href = (document.querySelector('meta[name="base"]') || {}).content
              ? document.querySelector('meta[name="base"]').content + 'thanks/'
              : '/recn-website/thanks/';
          }).catch(function() {
            window.location.href = '/recn-website/thanks/';
          });
        });
      });
    })();

    /* ---- Scroll reveal ---- */
    (function() {
      var els = document.querySelectorAll('.reveal');
      if (!els.length || !('IntersectionObserver' in window)) {
        els.forEach(function(el) { el.classList.add('revealed'); });
        return;
      }
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            e.target.classList.add('revealed');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      els.forEach(function(el) { obs.observe(el); });
    })();

    /* ---- Dot grid — mouse reactive (desktop only) ---- */
    (function() {
      var c = document.getElementById('bg-canvas');
      if (!c || !matchMedia('(hover:hover) and (min-width:600px)').matches) return;
      var ctx = c.getContext('2d');
      if (!ctx) return;
      var w, h, mx = -9e3, my = -9e3, tx = -9e3, ty = -9e3;
      var running = false, G = 48, R = 180;

      function dimColor() {
        var t = document.documentElement.dataset.theme;
        if (t === 'light') return 'rgba(0,0,0,0.035)';
        if (t === 'dark') return 'rgba(255,255,255,0.022)';
        return 'rgba(255,255,255,0.015)';
      }

      function resize() {
        w = c.width = innerWidth;
        h = c.height = innerHeight;
        paint();
      }

      function paint() {
        tx += (mx - tx) * 0.06;
        ty += (my - ty) * 0.06;
        ctx.clearRect(0, 0, w, h);

        var dim = dimColor();
        for (var x = G / 2; x < w; x += G) {
          for (var y = G / 2; y < h; y += G) {
            var dx = tx - x, dy = ty - y, d2 = dx * dx + dy * dy;
            if (d2 < R * R) {
              var inf = 1 - Math.sqrt(d2) / R;
              ctx.fillStyle = 'rgba(198,40,40,' + (0.05 + inf * 0.2) + ')';
              ctx.fillRect(x - 1, y - 1, 2, 2);
            } else {
              ctx.fillStyle = dim;
              ctx.fillRect(x, y, 1, 1);
            }
          }
        }

        var ddx = mx - tx, ddy = my - ty;
        if (ddx * ddx + ddy * ddy > 0.5) {
          requestAnimationFrame(paint);
        } else {
          running = false;
        }
      }

      function go() { if (!running) { running = true; paint(); } }

      resize();
      addEventListener('resize', resize);
      document.addEventListener('mousemove', function(e) { mx = e.clientX; my = e.clientY; go(); });
      document.addEventListener('mouseleave', function() { mx = my = -9e3; go(); });

      new MutationObserver(function() { go(); })
        .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    })();
  </script>
</body>
</html>
